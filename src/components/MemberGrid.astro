---
import { members } from "../data/team";

const categories = Array.from(new Set(members.flatMap((member) => member.focus))).sort();
const socialLabels = {
  instagram: "Instagram",
  x: "X",
  blog: "Blog",
  github: "GitHub",
  discord: "Discord",
  linkedin: "LinkedIn",
};

const socialPaths = {
  instagram: "M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7Zm5 4a4 4 0 1 1 0 8 4 4 0 0 1 0-8Zm0 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm4.8-3.4a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2Z",
  x: "M4 4h4.7l4.1 5.4L17.5 4H20l-6 6.9L20.5 20h-4.7l-4.4-5.9L6.2 20H3.7l6.5-7.4L4 4Zm3.2 1.8 9.5 12.4h1.6L8.8 5.8H7.2Z",
  blog: "M4 5a2 2 0 0 1 2-2h8l6 6v10a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V5Zm10 0v5h5M7 13h10M7 16h10M7 19h6",
  github: "M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 2.9.8.1-.7.4-1.1.7-1.3-2.3-.3-4.7-1.2-4.7-5A3.9 3.9 0 0 1 6.5 8.8c-.1-.3-.5-1.3.1-2.7 0 0 .9-.3 2.8 1a9.7 9.7 0 0 1 5.2 0c1.9-1.3 2.8-1 2.8-1 .6 1.4.2 2.4.1 2.7a3.9 3.9 0 0 1 1.1 2.8c0 3.9-2.4 4.8-4.7 5 .4.3.7 1 .7 2v2.4c0 .3.2.6.8.5A10 10 0 0 0 12 2Z",
  discord: "M17.5 6.9a13.2 13.2 0 0 0-3.3-1 6 6 0 0 0-.4.8 12.2 12.2 0 0 0-3.6 0 6 6 0 0 0-.4-.8 13 13 0 0 0-3.3 1C4.4 10 3.8 13 4.1 16a13.3 13.3 0 0 0 4 2 10 10 0 0 0 .8-1.3 9 9 0 0 1-1.2-.6l.3-.2a9.4 9.4 0 0 0 8 0l.3.2a8 8 0 0 1-1.2.6 10 10 0 0 0 .8 1.3 13.2 13.2 0 0 0 4-2c.3-3.4-.6-6.4-2.4-9.1ZM9.3 14.2c-.8 0-1.4-.7-1.4-1.6s.6-1.6 1.4-1.6 1.5.7 1.4 1.6c0 .9-.6 1.6-1.4 1.6Zm5.4 0c-.8 0-1.4-.7-1.4-1.6s.6-1.6 1.4-1.6 1.5.7 1.4 1.6c0 .9-.6 1.6-1.4 1.6Z",
  linkedin: "M5 3.5a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM3.5 9h3v11h-3V9Zm5.5 0h2.9v1.5h.1c.4-.8 1.5-1.8 3.1-1.8 3.3 0 3.9 2.2 3.9 5V20h-3v-5.6c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9V20H9V9Z",
};
---

<div class="filter-bar" data-member-filters>
  <button class="is-active" type="button" data-filter="all">All</button>
  {categories.map((category) => (
    <button type="button" data-filter={category}>{category}</button>
  ))}
</div>

<div class="member-list" data-member-list>
  {members.map((member) => (
    <article class="member-profile" data-categories={member.focus.join(" ")}>
      <img src={member.avatar} alt={`${member.name} avatar`} width="64" height="64" loading="lazy" />
      <div class="member-body">
        <div class="member-main">
          <h3>{member.name}</h3>
          {member.socials && (
            <div class="member-socials" aria-label={`${member.name} socials`}>
              {Object.entries(member.socials).slice(0, 3).map(([type, href]) => (
                <a href={href} target="_blank" rel="noreferrer" aria-label={`${member.name} ${socialLabels[type] ?? type}`} title={socialLabels[type] ?? type}>
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d={socialPaths[type] ?? socialPaths.blog}></path>
                  </svg>
                </a>
              ))}
            </div>
          )}
        </div>
        <p class="muted">{member.role}</p>
        {member.quote && <p class="member-quote">{member.quote}</p>}
        <div class="tags">
          {member.focus.map((item) => <span class="tag">{item}</span>)}
        </div>
      </div>
    </article>
  ))}
</div>

<script>
  function setupMemberFilters() {
    const filterRoot = document.querySelector("[data-member-filters]");
    const memberRows = Array.from(document.querySelectorAll("[data-member-list] [data-categories]"));
    if (!filterRoot) return;

    filterRoot.addEventListener("click", (event) => {
      const button = event.target instanceof HTMLElement ? event.target.closest("button") : null;
      if (!button) return;

      const selected = button.dataset.filter || "all";
      filterRoot.querySelectorAll("button").forEach((item) => item.classList.toggle("is-active", item === button));

      memberRows.forEach((row) => {
        const categories = row.getAttribute("data-categories") || "";
        row.toggleAttribute("hidden", selected !== "all" && !categories.split(" ").includes(selected));
      });
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupMemberFilters);
  } else {
    setupMemberFilters();
  }
</script>
