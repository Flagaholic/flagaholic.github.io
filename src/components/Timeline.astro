---
import { originSideEvent, timeline } from "../data/team";

const flagFillPath =
  "M0 20 C42 28 82 28 114 20 C146 12 188 12 228 20 L228 112 C188 104 146 104 114 112 C82 120 42 120 0 112 Z";
const flagStrokeAttachLeft =
  "M0 20 C42 28 82 28 114 20 C146 12 188 12 228 20 L228 112 C188 104 146 104 114 112 C82 120 42 120 0 112";
const flagStrokeAttachRight =
  "M228 20 C188 12 146 12 114 20 C82 28 42 28 0 20 L0 112 C42 120 82 120 114 112 C146 104 188 104 228 112";
const flagPolePath = "M0 20 L0 170";

const linkAttrs = (href?: string) =>
  href?.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

<section class="timeline-preview">
  <ol class="symbol-timeline" aria-label="flagaholic symbol timeline">
    {timeline.map((item, index) => {
      const isOrigin = item.origin === true;
      const side = index % 2 === 1 ? "right" : "left";
      const EntryTag = item.href && !isOrigin ? "a" : "article";
      const OriginSideTag = originSideEvent.href ? "a" : "article";

      return (
        <>
          {index > 0 && (
            <li class="symbol-flow" aria-hidden="true"></li>
          )}
          <li class:list={["symbol-item", isOrigin ? "symbol-origin" : `symbol-${side}`]}>
            {isOrigin && (
              <OriginSideTag
                class:list={["timeline-entry", "timeline-origin-side", `timeline-tier-${originSideEvent.tier ?? "normal"}`]}
                href={originSideEvent.href}
                {...linkAttrs(originSideEvent.href)}
                aria-label={`Open ${originSideEvent.title}${originSideEvent.rank ? ` ${originSideEvent.rank}` : ""}`}
              >
                <svg class="timeline-flag" viewBox="0 0 228 128" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                  <path class="timeline-flag-fill" d={flagFillPath}></path>
                  <path class="timeline-flag-pole" d={flagPolePath}></path>
                  <path class="timeline-flag-stroke" d={flagStrokeAttachLeft}></path>
                </svg>
                <div class="timeline-entry-body">
                  <time>{originSideEvent.date}</time>
                  <h2>
                    {originSideEvent.title}
                    {originSideEvent.rank && <span> ({originSideEvent.rank})</span>}
                  </h2>
                  <p>{originSideEvent.detail}</p>
                </div>
              </OriginSideTag>
            )}
            <EntryTag
              class:list={["timeline-entry", `timeline-tier-${item.tier ?? "normal"}`, isOrigin && "timeline-origin-entry", isOrigin && "timeline-entry-plain"]}
              href={item.href}
              {...linkAttrs(item.href)}
              aria-label={item.href ? `Open ${item.title}${item.rank ? ` ${item.rank}` : ""}` : undefined}
            >
              {!isOrigin && (
                <svg class="timeline-flag" viewBox="0 0 228 128" preserveAspectRatio="none" aria-hidden="true" focusable="false">
                  <path class="timeline-flag-fill" d={flagFillPath}></path>
                  <path class="timeline-flag-stroke" d={side === "right" ? flagStrokeAttachLeft : flagStrokeAttachRight}></path>
                </svg>
              )}
              <div class="timeline-entry-body">
                <time>{item.date}</time>
                <h2>
                  {item.title}
                  {item.rank && <span> ({item.rank})</span>}
                </h2>
                <p>{item.detail}</p>
              </div>
            </EntryTag>
            {!isOrigin && (
              <span class="symbol-branch" aria-hidden="true">
                <span class="symbol-arrow"></span>
              </span>
            )}
          </li>
        </>
      );
    })}
  </ol>
</section>
