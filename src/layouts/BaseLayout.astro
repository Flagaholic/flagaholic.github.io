---
import "../styles/global.css";
import { team } from "../data/team";

const nav = [
  { href: "/", label: "Home" },
  { href: "/members/", label: "Members" },
  { href: "/achievements/", label: "Achievements" },
  { href: "/writeups/", label: "Writeups" },
  { href: "/contact/", label: "Contact" },
];

const { title = team.name, description = team.description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/assets/favicon/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="header-inner">
          <a class="brand" href="/">
            <img src="/assets/teamlogo.png" alt="" width="32" height="32" />
            <span>{team.name}</span>
          </a>
          <nav class="nav" aria-label="Main navigation">
            {nav.map((item) => (
              <a
                href={item.href}
                aria-current={currentPath === item.href ? "page" : undefined}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <slot />

      <footer class="site-footer">
        <div class="footer-inner">
          <span>2026 flagaholic™</span>
          <span class="footer-social-group">
            <a class="footer-social" href={team.instagramUrl} aria-label="Instagram" title="Instagram">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7Zm5 4a4 4 0 1 1 0 8 4 4 0 0 1 0-8Zm0 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm4.8-3.4a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2Z"/></svg>
            </a>
            <a class="footer-social" href={team.ctftimeUrl} aria-label="CTFtime" title="CTFtime">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5h15v14 H4l6 -7"/></svg>
            </a>
            <a class="footer-social" href={team.githubUrl} aria-label="GitHub" title="GitHub">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 2.9.8.1-.7.4-1.1.7-1.3-2.3-.3-4.7-1.2-4.7-5A3.9 3.9 0 0 1 6.5 8.8c-.1-.3-.5-1.3.1-2.7 0 0 .9-.3 2.8 1a9.7 9.7 0 0 1 5.2 0c1.9-1.3 2.8-1 2.8-1 .6 1.4.2 2.4.1 2.7a3.9 3.9 0 0 1 1.1 2.8c0 3.9-2.4 4.8-4.7 5 .4.3.7 1 .7 2v2.4c0 .3.2.6.8.5A10 10 0 0 0 12 2Z"/></svg>
            </a>
            <a class="footer-social" href={team.discordInvite} aria-label="Discord" title="Discord">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M 17.545 6.907 a 13.2 13.2 0 0 0 -3.257 -1.011 a 0.05 0.05 0 0 0 -0.052 0.025 c -0.141 0.25 -0.297 0.577 -0.406 0.833 a 12.2 12.2 0 0 0 -3.658 0 a 8 8 0 0 0 -0.412 -0.833 a 0.05 0.05 0 0 0 -0.052 -0.025 c -1.125 0.194 -2.22 0.534 -3.257 1.011 a 0.04 0.04 0 0 0 -0.451 0.093 C 4.356 10.024 3.787 13.047 4.066 16.032 q 0.003 0.022 0.021 0.037 a 13.3 13.3 0 0 0 3.995 2.02 a 0.05 0.05 0 0 0 0.056 -0.019 q 0.463 -0.63 0.818 -1.329 a 0.05 0.05 0 0 0 -0.01 -0.059 l -0.018 -0.011 a 9 9 0 0 1 -1.248 -0.595 a 0.05 0.05 0 0 1 -0.02 -0.066 l 0.015 -0.019 q 0.127 -0.095 0.248 -0.195 a 0.05 0.05 0 0 1 0.051 -0.007 c 2.619 1.196 5.454 1.196 8.041 0 a 0.05 0.05 0 0 1 0.053 0.007 q 0.121 0.1 0.248 0.195 a 0.05 0.05 0 0 1 -0.004 0.085 a 8 8 0 0 1 -1.249 0.594 a 0.05 0.05 0 0 0 -0.03 0.03 a 0.05 0.05 0 0 0 0.003 0.041 c 0.24 0.465 0.515 0.909 0.817 1.329 a 0.05 0.05 0 0 0 0.056 0.019 a 13.2 13.2 0 0 0 4.001 -2.02 a 0.05 0.05 0 0 0 0.021 -0.037 c 0.334 -3.451 -0.559 -6.449 -2.366 -9.106 a 0.03 0.03 0 0 0 -0.02 -0.019 m -8.198 7.307 c -0.789 0 -1.438 -0.724 -1.438 -1.612 s 0.637 -1.613 1.438 -1.613 c 0.807 0 1.45 0.73 1.438 1.613 c 0 0.888 -0.637 1.612 -1.438 1.612 m 5.316 0 c -0.788 0 -1.438 -0.724 -1.438 -1.612 s 0.637 -1.613 1.438 -1.613 c 0.807 0 1.451 0.73 1.438 1.613 c 0 0.888 -0.631 1.612 -1.438 1.612"/></svg>
            </a>
          </span>
          <span class="footer-made">Made with <a href="https://astro.build/" style="color: aqua;">Astro</a></span>
        </div>
      </footer>
    </div>
  </body>
</html>
