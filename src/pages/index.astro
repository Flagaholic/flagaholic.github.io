---
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/Timeline.astro";
import WriteupList from "../components/WriteupList.astro";
import { team } from "../data/team";
import { getCollection } from "astro:content";

const writeups = await getCollection("writeups");
---

<BaseLayout title="flagaholic">
  <main class="page page-narrow">
    <section class="intro home-intro">
      <img class="intro-logo" src="/assets/teamlogo.png" alt="" width="96" height="96" />
      <div>
        <!-- i only used html escape because astro dont like {}s -->
        <p class="eyebrow">holic&#123;w3lc0m3_t0_0ur_1n7r0_:DDDDD&#125;</p>
        <h1>flagaholic</h1>
        <p class="lede">{team.description}</p>
      </div>
    </section>

    <div class="home-sections">
      <Timeline />
      <section>
        <h2>Latest writeups</h2>
        <WriteupList writeups={writeups.slice(0, 3)} compact={true} />
      </section>
    </div>
  </main>
</BaseLayout>
